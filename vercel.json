{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/developer",
      "destination": "/developer.html"
    },
    {
      "source": "/focus-blocker/chromewebstore",
      "destination": "/extension-chromewebstore.html"
    },
    {
      "source": "/tab-sorter-pro/chromewebstore",
      "destination": "/extension-chromewebstore.html"
    },
    {
      "source": "/human-doc-typer/chromewebstore",
      "destination": "/extension-chromewebstore.html"
    }
  ]
}
